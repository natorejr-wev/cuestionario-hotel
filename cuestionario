<script>
  // Days checkboxes dynamic render
  const days = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
  const daysWrap = document.getElementById('daysWrap');
  days.forEach(d => {
    const label = document.createElement('label');
    label.className = 'option-item';
    label.style.cssText = 'flex:0 0 auto;min-width:80px;';
    label.innerHTML = `<input type="checkbox" name="busy_days" value="${d}"><span class="option-text">${d}</span>`;
    daysWrap.appendChild(label);
  });

  // Scale function
  const scaleValues = {};
  function setScale(name, val) {
    scaleValues[name] = val;
    document.getElementById(name + '_val').value = val;
    document.querySelectorAll(`#scale${name.charAt(0).toUpperCase()+name.slice(1)} .scale-btn`).forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.val) <= val);
    });
    updateProgress();
  }

  // Show resolution textarea if pain points selected (not "sin_problemas")
  document.querySelectorAll('input[name="pain_points"]').forEach(cb => {
    cb.addEventListener('change', () => {
      const anyPain = [...document.querySelectorAll('input[name="pain_points"]:checked')]
        .some(el => el.value !== 'sin_problemas');
      document.getElementById('pain_resolution_q').style.display = anyPain ? 'block' : 'none';
      updateProgress();
    });
  });

  // Progress tracking
  const requiredFields = ['hotel_name','contact_name','contact_email','parking_price','parking_mgmt','has_valet','model_openness','wants_proposal'];
  
  function updateProgress() {
    let filled = 0;
    requiredFields.forEach(name => {
      const inputs = document.querySelectorAll(`[name="${name}"]`);
      if (inputs.length === 0) return;
      if (inputs[0].type === 'radio') {
        if ([...inputs].some(i => i.checked)) filled++;
      } else if (inputs[0].value.trim()) {
        filled++;
      }
    });
    // count scale
    if (scaleValues['importance']) filled++;
    const total = requiredFields.length + 1;
    const pct = Math.round((filled / total) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressLabel').textContent = `${filled} / ${total}`;
  }

  document.querySelectorAll('input, select, textarea').forEach(el => {
    el.addEventListener('change', updateProgress);
    el.addEventListener('input', updateProgress);
  });

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.section').forEach(s => observer.observe(s));

  // Submit
  document.getElementById('surveyForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Basic validation
    const required = ['hotel_name','contact_name','contact_email'];
    let valid = true;
    required.forEach(name => {
      const el = document.querySelector(`[name="${name}"]`);
      if (!el || !el.value.trim()) { el && (el.style.borderColor = 'rgba(200,100,100,0.6)'); valid = false; }
    });
    
    if (!document.querySelector('input[name="parking_price"]:checked')) valid = false;
    if (!document.querySelector('input[name="model_openness"]:checked')) valid = false;
    if (!document.querySelector('input[name="wants_proposal"]:checked')) valid = false;

    if (!valid) {
      alert('Por favor, completa los campos obligatorios antes de enviar.');
      return;
    }

    // Collect data
    const data = new FormData(this);
    const payload = {};
    for (let [k, v] of data.entries()) {
      if (payload[k]) {
        payload[k] = Array.isArray(payload[k]) ? [...payload[k], v] : [payload[k], v];
      } else {
        payload[k] = v;
      }
    }
    payload['importance_scale'] = scaleValues['importance'] || null;
    payload['submitted_at'] = new Date().toISOString();

    console.log('WeValet Survey Response:', JSON.stringify(payload, null, 2));

    // Show success
    document.getElementById('surveyForm').style.display = 'none';
    document.getElementById('successState').classList.add('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

